{
  "name": "@litert/utils-network",
  "version": "0.1.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "description": "The network utilities for JavaScript/TypeScript.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litert/utils.js.git"
  },
