{
  "name": "@litert/utils",
  "version": "0.1.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "description": "The utilities for JavaScript/TypeScript.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litert/utils.js.git"
  },
  "bugs": {
    "url": "https://github.com/litert/utils.js/issues"
  },
  "homepage": "https://github.com/litert/utils.js#readme",
  "scripts": {
    "ottoia:clean": "rm -rf lib tsconfig.tsbuildinfo",
    "ottoia:prepublish": "cp ../../LICENSE ./ && cp ../../README.md ./README.md",
    "ottoia:postpublish": "rm LICENSE README.md",
    "prepublishOnly": "echo \"Please use ottoia publishing this package!\"; exit 1;"
  },
  "license": "Apache-2.0",
  "private": false,
  "dependencies": {
    "@litert/utils-flow-control": "-",
    "@litert/utils-number": "-",
    "@litert/utils-object": "-",
    "@litert/utils-string": "-",
    "@litert/utils-ts-types": "-",
    "@litert/concurrent": "-",
    "@litert/utils-network": "-",
    "@litert/utils-array": "-",
    "@litert/utils-async": "-",
    "@litert/utils-test": "-"
  },
  "keywords": [
    "utility",
    "litert",
    "helper"
  ],
  "type": "module",
  "devDependencies": {},
  "peerDependencies": {},
  "ottoia:alias": "bundle",
  "engines": {
    "node": ">=22.0.0"
  },
  "access": "public",
  "exports": {
    ".": {
      "default": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./namespaces/Array": {
      "default": {
        "types": "./lib/Namespaces/Array.d.ts",
        "default": "./lib/Namespaces/Array.js"
      }
    },
    "./namespaces/Async": {
      "default": {
        "types": "./lib/Namespaces/Async.d.ts",
        "default": "./lib/Namespaces/Async.js"
      }
    },
    "./namespaces/Concurrent": {
      "default": {
        "types": "./lib/Namespaces/Concurrent.d.ts",
        "default": "./lib/Namespaces/Concurrent.js"
      }
    },
    "./namespaces/Network": {
      "default": {
        "types": "./lib/Namespaces/Network.d.ts",
        "default": "./lib/Namespaces/Network.js"
      }
    },
    "./namespaces/Number": {
      "default": {
        "types": "./lib/Namespaces/Number.d.ts",
        "default": "./lib/Namespaces/Number.js"
      }
    },
    "./namespaces/Object": {
      "default": {
        "types": "./lib/Namespaces/Object.d.ts",
        "default": "./lib/Namespaces/Object.js"
      }
    },
    "./namespaces/String": {
      "default": {
        "types": "./lib/Namespaces/String.d.ts",
        "default": "./lib/Namespaces/String.js"
      }
    },
    "./namespaces/Test": {
      "default": {
        "types": "./lib/Namespaces/Test.d.ts",
        "default": "./lib/Namespaces/Test.js"
      }
    }
  }
}